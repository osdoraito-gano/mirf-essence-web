{
  "rewrites": [
    {
      "source": "/((?!.js|.css|.png|.jpg|.svg|.ico|.json|.xml|.txt).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}